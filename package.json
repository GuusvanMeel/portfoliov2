{
  "name": "portfoliov2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "lighthouse:local": "npx lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html --view",
    "lighthouse:ci": "npm run build && lhci autorun",
    "lighthouse:summary": "node scripts/lighthouse-summary.mjs",
    "dev:coverage": "set CYPRESS_COVERAGE=true&& next dev",
    "cypress:open": "cypress open",
    "coverage:report": "nyc report --reporter=lcov --reporter=text-summary",
    "test:components": "vitest --browser.headless",
    "test:components:coverage": "vitest run --browser.headless --coverage --reporter=default --reporter=github-actions",
    "deps:reset": "if exist node_modules rmdir /s /q node_modules & if exist package-lock.json del package-lock.json & npm install && npm ci"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@testing-library/react": "^16.3.2",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vitest-browser-react": "^2.2.0"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^4.0.3",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-istanbul": "^8.0.0",
    "cypress": "^15.17.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
